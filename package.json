{
  "name": "@quranweb/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "download-data": "bun run scripts/download-data.ts"
  },
  "dependencies": {

    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.0",
    "typescript": "^5.7.0"
  }
}
